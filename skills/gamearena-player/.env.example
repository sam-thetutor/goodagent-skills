# Play mode: offchain (challenge-ai), onchain (G$ wagers), or auto (tickets first, then on-chain)
PLAY_MODE=offchain

# MARKOV throw strategy: random | sequence | fixed | counter
MARKOV_STRATEGY=random

# For sequence: comma-separated rock/paper/scissors (cycles every match throw)
RPS_SEQUENCE=rock,paper,scissors

# For fixed: always throw this move
RPS_FIXED=rock

# Wallet address for off-chain play (optional if PRIVATE_KEY is set — address is derived)
PLAYER_ADDRESS=

# Agent wallet private key — required for auto-refill, on-chain, and auto mode
PRIVATE_KEY=

# GameArena base URL (challenge-ai server actions live under /games/challenge-ai)
CHALLENGE_AI_URL=https://gamearenahq.xyz

# Celo RPC (refill payments and on-chain mode)
CELO_RPC_URL=https://forno.celo.org

# Off-chain: auto-buy ticket refills when free tickets run out (2 G$ → +5 matches)
AUTO_REFILL=1

# Off-chain: max G$ spent on refills per UTC day (0 = unlimited)
DAILY_REFILL_CAP_GS=20

# Off-chain: max refill purchases per UTC day (0 = unlimited)
MAX_REFILLS_PER_DAY=10

# Max matches per UTC day including after refills (0 = unlimited)
DAILY_MATCH_CAP=50

# On-chain: wager per match in G$ (hard cap enforced; default 1, max 5)
WAGER_GS=1

# Game to play: 0 = Rock-Paper-Scissors, 3 = Coin Flip (on-chain only; off-chain is RPS only)
GAME_TYPE=0

# On-chain: stop for the day after losing this much G$ cumulatively
DAILY_LOSS_CAP_GS=20

# On-chain: wait for MARKOV to accept a proposed match (default 90s when keeper is live)
ACCEPT_TIMEOUT_SECONDS=90

# On-chain: wait for match resolution after both players move
RESOLVE_TIMEOUT_SECONDS=120

# On-chain: poll interval while waiting for accept or completion
ACCEPT_POLL_SECONDS=5

# Maximum matches to play per run (0 = unlimited until cap)
MAX_MATCHES=10

# Seconds to wait between matches
MATCH_INTERVAL_SECONDS=300

# Set by GoodAgent host on deploy — reports matches/logs to Postgres
# DEPLOY_ID=
# GOODAGENT_HOST_URL=http://127.0.0.1:3010
# HOST_INTERNAL_SECRET=
