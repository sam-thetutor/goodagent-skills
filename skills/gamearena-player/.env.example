# Agent wallet private key (holds G$ for wagers + CELO for gas). NEVER commit.
PRIVATE_KEY=

# Celo RPC (default: public Forno)
CELO_RPC_URL=https://forno.celo.org

# Wager per match in G$ (hard cap enforced; default 1, max 5)
WAGER_GS=1

# Game to play: 0 = Rock-Paper-Scissors, 3 = Coin Flip
GAME_TYPE=0

# Stop for the day after losing this much G$ cumulatively
DAILY_LOSS_CAP_GS=20

# Maximum matches to play per run (0 = unlimited until loss cap)
MAX_MATCHES=10

# Seconds to wait between matches
MATCH_INTERVAL_SECONDS=300
