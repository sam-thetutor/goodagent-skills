# The agent's wallet address (used for leaderboard attribution). vs-house play
# is FREE — no private key or signing is required for the default mode.
PLAYER_ADDRESS=

# Display name on the ACTION-ORDER leaderboard
PLAYER_NAME=GoodAgent

# Character to play (kaira | kenji | riven | zane | elara).
# Default: best for the strategy (riven for anti_strike, zane for knock_max).
CHARACTER_ID=

# Strategy: anti_strike (default, defense-heavy — beats the strike-spamming
# house far more often) or knock_max (raw-damage order).
STRATEGY=anti_strike

# House AI difficulty: 0 = easiest … 3 = hardest
DIFFICULTY=0

# Comma-separated premium (Black Market) card ids your wallet owns, if any.
# Leave blank to play with the free base deck only.
PREMIUM_CARDS=

# Matches to play per run (0 = until the daily cap)
MAX_MATCHES=5

# Be-a-good-citizen cap on matches per UTC day (0 = unlimited)
DAILY_MATCH_CAP=50

# Seconds to wait between matches
MATCH_INTERVAL_SECONDS=10

# Override the base URL (default: production)
ACTIONORDER_URL=https://www.actionorder.xyz
